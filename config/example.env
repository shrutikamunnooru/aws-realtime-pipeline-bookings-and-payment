# AWS region where Kinesis, SQS, Glue, S3, and Redshift are created.
AWS_REGION=us-east-1

# Kinesis stream names used by the local mock data producer.
BOOKING_STREAM_NAME=bms-realtime-booking-events
PAYMENT_STREAM_NAME=bms-realtime-payment-events

# Producer behavior.
EVENT_INTERVAL_SECONDS=1.5
UNMATCHED_PAYMENT_RATE=0.08
OUT_OF_WINDOW_PAYMENT_RATE=0.04
FAILED_PAYMENT_RATE=0.07
